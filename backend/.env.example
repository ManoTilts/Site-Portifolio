# =============================================================================
# Portfolio backend configuration — copy to `.env` and fill in real values.
#   cp .env.example .env
# Required values have NO defaults; the app refuses to start without them.
# =============================================================================

# --- Required ----------------------------------------------------------------

# MongoDB connection string (mongodb:// or mongodb+srv://)
MONGODB_URL=mongodb://localhost:27017

# JWT signing secret — MUST be at least 32 characters and not a common default.
# Generate one with:  python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET_KEY=change-me-to-a-long-random-string-at-least-32-chars

# Admin account (created automatically on first startup).
# Password must be >= 12 chars and not a common/default value.
ADMIN_USERNAME=admin
ADMIN_EMAIL=you@yourdomain.com
ADMIN_PASSWORD=change-this-strong-password

# Email "from" + notification recipient (cannot be example.com).
FROM_EMAIL=you@yourdomain.com
ADMIN_EMAIL_RECIPIENT=you@yourdomain.com

# --- Optional (sane defaults shown) ------------------------------------------

DATABASE_NAME=portfolio_db

JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Email delivery (SendGrid preferred; SMTP as fallback)
# SENDGRID_API_KEY=
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USERNAME=
# SMTP_PASSWORD=

# File uploads
UPLOAD_DIR=uploads
MAX_FILE_SIZE=10485760
ALLOWED_IMAGE_EXTENSIONS=jpg,jpeg,png,gif,webp

# Rate limiting
RATE_LIMIT_CONTACT_FORM=5/minute
RATE_LIMIT_FILE_UPLOAD=10/minute

# Frontend origin allowed by CORS (set to your deployed frontend URL in prod)
FRONTEND_URL=http://localhost:5173
REDIS_URL=redis://localhost:6379

# development | testing | staging | production
ENVIRONMENT=development

LOG_LEVEL=INFO
LOG_FILE=logs/app.log
